# Copy to .env and fill in real values. (.env is gitignored.)
#
# LLM provider keys — consumed by the litellm-proxy container.
OPENAI_API_KEY=sk-your-openai-key
OLLAMA_API_KEY=your-ollama-cloud-key    # from https://ollama.com/settings/keys

# LiteLLM proxy master key. The backend authenticates to the proxy using
# LITELLM_API_KEY, which MUST equal LITELLM_MASTER_KEY.
LITELLM_MASTER_KEY=sk-litellm-master-change-me
LITELLM_API_KEY=sk-litellm-master-change-me